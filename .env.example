# Copy to .env on the production server (never commit real .env).
# Required for login and Acumatica sync.

# Public app URL — PRODUCTION ONLY (leave unset for local npm run dev)
NEXT_PUBLIC_BASE_PATH=/kgs-purchase
NEXT_PUBLIC_BASE_URL=http://190.92.233.232

# Acumatica ERP
ACUMATICA_BASE_URL=https://your-acumatica-host.example.com/ERP
ACUMATICA_COMPANY=KGSC
ACUMATICA_USERNAME=
ACUMATICA_PASSWORD=

# Emergency bypass (optional — used when API login limit is hit)
ACU_USERNAME=
ACU_PASSWORD=

# MySQL
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_INVENTORY_DATABASE=db_kelin_inventory
MYSQL_PURCHASE_DATABASE=db_purchase

# Sync API
SYNC_SECRET=

# Supabase (if used)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
